# Copy to .env (gitignored) for local `npm run server`. In production
# (Render), set these in the dashboard instead — see render.yaml.

# Postgres connection string (Neon, etc.) — see server/schema.sql for the
# one-time schema setup.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Any long random string — signs session tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changeme
